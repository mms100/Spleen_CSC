params {
    results_dir = "path/to/input"
    cond1 = 'WT'  // Default condition 1
    cond2 = 'D0'  // Default condition 2
    object = 'path/to/object'   // Path to the Seurat object (default is empty)
    cond_colname = 'stage' //column name of the conditions in the seurat metadate
    batch_colname = 'name' //column name of the batch  in the seurat metadate
    annotation = 'anno' //column name of the annotation in the seurat metadate
    input_dir = 'path/to/input'
    stat = 't_stat'
    geneID = 'GeneID'
    species = 'mouse'
}

process {
    withName: runMAST {
        executor = 'slurm'
        memory   = '50 GB'  // Increase this (e.g., 32GB, 64GB) depending on dataset size
        cpus     = 10
        time     = '96h'
    }
}